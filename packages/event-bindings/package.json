{
  "name": "@radroots/event-bindings",
  "version": "0.1.0",
  "description": "TypeScript bindings for radroots_event",
  "license": "MIT OR Apache-2.0",
  "homepage": "https://radroots.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/radrootslabs/sdk.git",
    "directory": "packages/event-bindings"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE-MIT",
    "LICENSE-APACHE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@radroots/core-bindings": "workspace:^"
  }
}
