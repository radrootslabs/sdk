{
  "name": "@radroots/replica-store-wasm",
  "version": "0.1.0",
  "description": "WebAssembly bindings for radroots_replica_store",
  "license": "MIT OR Apache-2.0",
  "homepage": "https://radroots.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/radrootslabs/sdk.git",
    "directory": "packages/replica-store-wasm"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE-MIT",
    "LICENSE-APACHE"
  ],
  "main": "./dist/radroots_replica_store_wasm.js",
  "types": "./dist/radroots_replica_store_wasm.d.ts",
  "exports": {
    ".": {
      "types": "./dist/radroots_replica_store_wasm.d.ts",
      "import": "./dist/radroots_replica_store_wasm.js",
      "default": "./dist/radroots_replica_store_wasm.js"
    }
  },
  "scripts": {
    "build": "cd ../.. && cargo xtask generate wasm --package replica_store",
    "typecheck": "tsc --noEmit --strict --module NodeNext --moduleResolution NodeNext --target ES2022 dist/radroots_replica_store_wasm.d.ts dist/radroots_replica_store_wasm_bg.wasm.d.ts"
  }
}
